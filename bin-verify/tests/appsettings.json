{
  "Shield": {
    "SingleUser": true,
    "Db": {
      "Shield": "Data Source=data/shield.db",
      "Feeds": "Data Source=data/feeds.db"
    },
    "OpenApi": { "Enabled": true },
    "Auth": {
      "JwtSigningKey": "CHANGE_ME_dev_only_signing_key_minimum_32_chars"
    },
    "Feeds": {
      "Osv": { "Enabled": true, "Cadence": "00:15:00" },
      "Ghsa": { "Enabled": true, "Cadence": "00:15:00", "ApiKey": "" },
      "NpmRegistry": { "Enabled": true, "Cadence": "00:15:00" }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
