{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Shield": {
    "OpenApi": { "Enabled": true },
    "Auth": {
      "JwtSigningKey": "dev-only-jwt-signing-key-minimum-48-characters-please",
      "ApiTokenPepper": "dev-only-api-token-pepper-48-chars-min-deterministic"
    }
  }
}
