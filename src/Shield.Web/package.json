{
  "name": "shield-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "audit": "npm audit --audit-level=high",
    "types:gen": "openapi-typescript http://localhost:5099/swagger/v1/swagger.json -o src/types/api.ts"
  },
  "dependencies": {
    "@microsoft/signalr": "^8.0.17",
    "@tanstack/vue-query": "^5.62.7",
    "axios": "^1.7.9",
    "lucide-vue-next": "^0.469.0",
    "qrcode": "^1.5.4",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.2",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "openapi-typescript": "^7.5.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.3",
    "vite": "^6.0.7",
    "vue-tsc": "^2.2.0"
  }
}
