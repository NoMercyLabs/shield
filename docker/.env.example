# =============================================================================
# Shield — production .env (copy to .env and fill in real values)
# =============================================================================
#
# DO NOT commit this file once filled. .env is already in .gitignore at the repo root.
#
# Real secrets are non-negotiable. A weak or shared value here is worse than no value at
# all — every Shield instance on the public internet sharing the same JwtSigningKey or
# DataProtectionMasterKey would share the same trust boundary. The ProductionSafetyGate
# (src/Shield.Api/Hardening/ProductionSafetyGate.cs) refuses to boot the container when
# any of these fall below the required floor.
#
# Generate secrets with:
#   openssl rand -base64 48

# -----------------------------------------------------------------------------
# REQUIRED — runtime environment
# -----------------------------------------------------------------------------

# Locks the host into Production mode. The ProductionSafetyGate runs only outside
# Development/Testing; flipping this to Development silently disables every check below.
ASPNETCORE_ENVIRONMENT=Production

# -----------------------------------------------------------------------------
# REQUIRED — secrets
# -----------------------------------------------------------------------------

# Symmetric HMAC-SHA256 key for JWT bearer tokens. Minimum 48 characters in Production.
# Generate with: openssl rand -base64 48
Shield__Auth__JwtSigningKey=REPLACE_WITH_openssl_rand_base64_48_OUTPUT__must_be_at_least_48_chars

# Master key that wraps the DataProtection keyring under /app/data/keys. Minimum
# 32 characters. MUST be backed up to your password manager — if you lose it, every
# stored OAuth token / webhook URL / OIDC client secret becomes permanently unrecoverable
# AND every active session cookie is invalidated. Refusing to start when this is the
# dev default ('dev-master-key-at-least-32-chars-long-xx') is by design.
# Generate with: openssl rand -base64 36   (any value ≥32 chars is accepted)
Shield__Auth__DataProtectionMasterKey=REPLACE_WITH_openssl_rand_base64_36_OUTPUT__at_least_32_chars

# -----------------------------------------------------------------------------
# REQUIRED — public-exposure posture
# -----------------------------------------------------------------------------

# Marks this instance as internet-exposed. Tightens password policy, blocks Swagger
# unconditionally, and (on the first boot after a LAN-era install) revokes every stored
# OAuth token plus bumps every user's SecurityStamp so stale cookies from before public
# exposure cannot resurface.
Shield__Public=true

# Required when Public=true. The reverse proxy (cloudflared / Caddy / nginx) terminates
# TLS; this flag tells Shield to issue Secure cookies with SameSite=Strict, emit HSTS,
# and short-circuit any http:// callbacks.
Shield__Auth__RequireHttps=true

# Pin the auth cookie to your tunnel hostname. Without this the cookie is host-only and
# tunnels that rewrite the Host header (cloudflared, ngrok, oauth2-proxy fronts) silently
# break SPA auth. The gate refuses to boot with Public=true and CookieDomain unset.
Shield__Auth__CookieDomain=shield.example.com

# Multi-user mode is the production default. Leave as-is. The ProductionSafetyGate
# refuses to boot with SingleUser=true unless Shield__Auth__AllowSingleUserInProduction
# is set (strongly discouraged — see docs/internet-exposure.md).
Shield__SingleUser=false

# -----------------------------------------------------------------------------
# REQUIRED — reverse-proxy trust
# -----------------------------------------------------------------------------
# Shield reads X-Forwarded-For / X-Forwarded-Proto from the immediate upstream hop and
# refuses to honour them from any other source (the connection IP stays the real client
# so audit logs cannot be spoofed). Tell it which hops to trust here.

# Single proxy IP — the cloudflared / Caddy host. Loopback is always trusted by default,
# so this is only needed when the proxy speaks to Shield over the docker bridge instead
# of via 127.0.0.1.
Shield__ForwardedHeaders__KnownProxies=127.0.0.1

# CIDR network the proxy lives in. Use the Docker bridge range when running the
# cloudflared sidecar — the sidecar's container IP changes on each boot, so trusting the
# whole bridge subnet is more robust than re-pinning a fixed IP. Leave commented out when
# cloudflared runs on the host (the loopback default is enough).
# Shield__ForwardedHeaders__KnownNetworks=172.16.0.0/12

# -----------------------------------------------------------------------------
# REQUIRED — SQLite paths
# -----------------------------------------------------------------------------
# These default inside the image to /app/data/<name>.db, mounted from the `shield-data`
# named volume in docker-compose.yml. Override only when remapping the volume.

Shield__Db__Shield=Data Source=/app/data/shield.db
Shield__Db__Feeds=Data Source=/app/data/feeds.db

# -----------------------------------------------------------------------------
# OPTIONAL — feeds + integrations
# -----------------------------------------------------------------------------

# GitHub PAT for the GHSA feed (public_repo scope is enough). Without one the GHSA feed
# is rate-limited to 60 req/h and effectively unusable. Per-source tokens for private
# repo scanning are configured in the UI, not here.
# Shield__Feeds__Ghsa__Token=ghp_...

# -----------------------------------------------------------------------------
# CLOUDFLARE TUNNEL SIDECAR — only when using docker-compose.cloudflared.yml
# -----------------------------------------------------------------------------
#
# Skip this section if cloudflared runs on the Docker host (the primary path documented
# in docs/deploy.md). The variable is consumed only when the overlay is layered on.
#
# Create the tunnel in the Cloudflare dashboard:
#   Zero Trust -> Networks -> Tunnels -> Create a tunnel -> Cloudflared
# Copy the connector token (long base64 string) into the value below. Then in the same
# dashboard, set the tunnel's Public Hostname to point at
#   http://shield:8842
# That DNS name resolves inside the compose network — NOT to localhost.
#
# When you switch to the sidecar, also enable the KnownNetworks line above so Shield
# trusts X-Forwarded-Proto from cloudflared's bridge IP.

# TUNNEL_TOKEN=eyJ...
